{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 200,
      "title": "🔌 Connection Pool Overview",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Active connections currently checked out from the pool. Sustained high values mean the pool is under pressure.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "never",
            "spanNulls": false
          },
          "min": 0,
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 8 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "hikaricp_connections_active{job=~\"$service\", pool=~\"$pool\"}",
          "legendFormat": "{{job}} — {{pool}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Active connections",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Idle connections waiting in the pool. Too many idle connections waste resources; too few cause spikes in acquisition time.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "never",
            "spanNulls": false
          },
          "min": 0,
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["mean", "min"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "hikaricp_connections_idle{job=~\"$service\", pool=~\"$pool\"}",
          "legendFormat": "{{job}} — {{pool}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Idle connections",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Threads currently waiting to acquire a connection. Any sustained value above 0 indicates pool exhaustion.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "min": 0,
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "hikaricp_connections_pending{job=~\"$service\", pool=~\"$pool\"}",
          "legendFormat": "{{job}} — {{pool}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Pending threads (pool exhaustion indicator)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Pool utilisation = active / max. Values near 100% indicate the pool is close to exhaustion.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "max": 100,
          "min": 0,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "100 * hikaricp_connections_active{job=~\"$service\", pool=~\"$pool\"} / hikaricp_connections_max{job=~\"$service\", pool=~\"$pool\"}",
          "legendFormat": "{{job}} — {{pool}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Pool utilisation %",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 201,
      "title": "📊 Pool Size Limits",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Configured max and min pool size per service. Use this to verify Hikari settings are applied correctly.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 0,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "min": 0,
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "max.*" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [10, 5], "fill": "dash" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 18 },
      "id": 5,
      "options": {
        "legend": { "calcs": [], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "hikaricp_connections_max{job=~\"$service\", pool=~\"$pool\"}",
          "legendFormat": "max — {{job}}",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "hikaricp_connections_min{job=~\"$service\", pool=~\"$pool\"}",
          "legendFormat": "min — {{job}}",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Max / min pool size",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Total connection timeout events. Each event means a thread waited longer than connectionTimeout and got an exception. Any non-zero value is a serious issue.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 70,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "min": 0,
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 18 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "increase(hikaricp_connections_timeout_total{job=~\"$service\", pool=~\"$pool\"}[$__rate_interval])",
          "legendFormat": "{{job}} — {{pool}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Connection timeout events",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 202,
      "title": "⏱ Connection Timing",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Average time a thread waits to acquire a connection from the pool. Values above 10ms indicate pool pressure. Spikes correlate with pending thread spikes.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 26 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "rate(hikaricp_connections_acquire_seconds_sum{job=~\"$service\", pool=~\"$pool\"}[$__rate_interval]) / rate(hikaricp_connections_acquire_seconds_count{job=~\"$service\", pool=~\"$pool\"}[$__rate_interval])",
          "legendFormat": "{{job}} — {{pool}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Avg connection acquisition time",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Average time to create a brand-new physical connection to the database. High values indicate network or database startup latency.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 26 },
      "id": 8,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "rate(hikaricp_connections_creation_seconds_sum{job=~\"$service\", pool=~\"$pool\"}[$__rate_interval]) / rate(hikaricp_connections_creation_seconds_count{job=~\"$service\", pool=~\"$pool\"}[$__rate_interval])",
          "legendFormat": "{{job}} — {{pool}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Avg connection creation time",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Average time a connection is held by a thread (from borrow to return). High values mean slow queries or long transactions.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 26 },
      "id": 9,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "rate(hikaricp_connections_usage_seconds_sum{job=~\"$service\", pool=~\"$pool\"}[$__rate_interval]) / rate(hikaricp_connections_usage_seconds_count{job=~\"$service\", pool=~\"$pool\"}[$__rate_interval])",
          "legendFormat": "{{job}} — {{pool}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Avg connection usage time (hold time)",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "id": 203,
      "title": "📋 Current Status — per service",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Current snapshot of all pool counters per service. Useful for a quick health check without reading time series.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "center", "displayMode": "color-background-solid" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Active" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "orange", "value": 8 },
                    { "color": "red", "value": 10 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Pending" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "orange", "value": 1 },
                    { "color": "red", "value": 3 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Utilisation %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "orange", "value": 70 },
                    { "color": "red", "value": 90 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 35 },
      "id": 10,
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": false, "displayName": "Service" }]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "hikaricp_connections_active{job=~\"$service\", pool=~\"$pool\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "active"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "hikaricp_connections_idle{job=~\"$service\", pool=~\"$pool\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "idle"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "hikaricp_connections_pending{job=~\"$service\", pool=~\"$pool\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "pending"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "hikaricp_connections_max{job=~\"$service\", pool=~\"$pool\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "max"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "100 * hikaricp_connections_active{job=~\"$service\", pool=~\"$pool\"} / hikaricp_connections_max{job=~\"$service\", pool=~\"$pool\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "util"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "pool", "mode": "outer" }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": ["job", "pool", "Value #active", "Value #idle", "Value #pending", "Value #max", "Value #util"]
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "job": "Service",
              "pool": "Pool",
              "Value #active": "Active",
              "Value #idle": "Idle",
              "Value #pending": "Pending",
              "Value #max": "Max",
              "Value #util": "Utilisation %"
            }
          }
        }
      ],
      "title": "Connection pool snapshot",
      "type": "table"
    }

  ],

  "schemaVersion": 36,
  "style": "dark",
