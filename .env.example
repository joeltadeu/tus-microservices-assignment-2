# =============================================================================
# .env.example – Environment variable template
#
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in the values (see comments below for guidance)
#   3. NEVER commit the .env file to git (.gitignore should already exclude it)
#
# Docker Compose automatically loads variables from a .env file
# located in the same directory as docker-compose.yml.
# =============================================================================

# ─── JWT Configuration ─────────────────────────────────────────────────────────

# Secret key used to sign and validate JWT tokens.
#
# Generate a secure random string (recommended 256-bit or longer).
# Examples:
#   - openssl rand -hex 32
#   - https://www.uuidgenerator.net/ (less secure, but acceptable for dev)
#
# ⚠️ Keep this value secret and never share it publicly.
JWT_SECRET=your-secure-random-secret-here


# Git repository URI that the Config Server (infra-config-server) reads from.
#
# Examples:
#   GitHub (HTTPS, public):  https://github.com/your-org/pms-config-repo.git
#   GitHub (HTTPS, private): https://github.com/your-org/pms-config-repo.git
#                            (set CONFIG_GIT_USERNAME / CONFIG_GIT_PASSWORD too)
#   GitHub (SSH):            git@github.com:your-org/pms-config-repo.git
#   Local filesystem (dev):  file:///path/to/pms-config-repo
#
# ⚠️ The repository must be accessible from inside the Docker network at startup.
CONFIG_GIT_URI=https://github.com/your-org/pms-config-repo.git

# Branch to read configuration from (default: main)
CONFIG_GIT_BRANCH=main